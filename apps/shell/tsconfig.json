{
  "extends": "@cowork/typescript-config/vite.json",
  "include": ["src", "@mf-types"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "cowork_profile/*": ["./@mf-types/cowork_profile/*"],
      "cowork_issue/*": ["./@mf-types/cowork_issue/*"],
      "cowork_chat/*": ["./@mf-types/cowork_chat/*"]
    }
  }
}
